# Neon Postgres — get from console.neon.tech
# Format: postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/jobsdb?sslmode=require

# LinkedIn credentials (use a throwaway account recommended)
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword

# Optional: slow down scrapers to avoid blocks (seconds)
SCRAPE_DELAY=3

# Job search config
SEARCH_KEYWORDS=DevOps Engineer,Cloud Engineer,SRE,Platform Engineer,MLOps
SEARCH_LOCATION=Dublin, Ireland
SEARCH_RADIUS_KM=50
MAX_PAGES_PER_SOURCE=5
